# econOS Environment Variables
# Copy this file to config.js and fill in your values.
# See SETUP.md for full instructions.

# Your Supabase project URL
# Found at: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
# Found at: Supabase Dashboard → Project Settings → API → Project API Keys → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NOTE: This is a static HTML project with no build step.
# These values go directly into econos/assets/js/config.js — not a .env file.
# This file is for documentation purposes only.
